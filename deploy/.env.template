# AD Biz Sys - Environment Configuration Template
# Copy this file to .env and fill in the actual values

# Application
APP_NAME=AD Biz Sys
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://aduser:adpass@localhost:5432/adbizsys
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Active Directory
AD_DOMAIN=company.local
AD_DC_LIST=["dc01.company.local","dc02.company.local"]
AD_LDAPS_PORT=636
AD_SEARCH_BASE=DC=company,DC=local
AD_SERVICE_ACCOUNT_DN=CN=svc_adbiz,OU=Service Accounts,DC=company,DC=local
AD_SERVICE_ACCOUNT_PASSWORD=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SAML IdP
SAML_IDP_CERT_PATH=/path/to/idp.crt
SAML_IDP_KEY_PATH=/path/to/idp.key
SAML_IDP_ENTITY_ID=https://ad-biz-sys.company.local/saml/metadata

# Exchange
EXCHANGE_SERVER=mail.company.local
EXCHANGE_USERNAME=svc_adbiz@company.local
EXCHANGE_PASSWORD=CHANGE_ME

# Auth
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_ACCOUNT_LOCKOUT_MINUTES=30

# Sync
ORG_SYNC_INTERVAL_MINUTES=5
GAL_SYNC_INTERVAL_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://ad-biz-sys.company.local"]

# NTP
NTP_SERVER=time.windows.com